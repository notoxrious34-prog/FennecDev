{
    "name": "fennec-facturation",
    "productName": "Fennec Facturation",
    "description": "Professional invoice management and client tracking for small businesses",
    "author": "Fennec Applications",
    "private": true,
    "version": "3.2.0",
    "main": "main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "electron .",
        "electron:dev": "electron .",
        "electron:build": "electron-builder",
        "dist": "electron-builder",
        "predist": "node scripts/preDistCheck.js",
        "version:patch": "node scripts/bumpVersion.js patch",
        "version:minor": "node scripts/bumpVersion.js minor",
        "version:major": "node scripts/bumpVersion.js major",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "test:ui": "vitest --ui --config vitest.config.ts",
        "test:coverage": "vitest run --coverage --config vitest.config.ts",
        "preDistCheck": "npm run test && npm run build",
        "release": "powershell -ExecutionPolicy Bypass -File scripts/build-release.ps1 -Version",
        "release:dry": "powershell -ExecutionPolicy Bypass -File scripts/build-release.ps1 -Version 0.0.0 -DryRun"
    },
    "dependencies": {
        "@fontsource/cairo": "^5.1.0",
        "@fontsource/inter": "^5.1.0",
        "@google/genai": "^1.29.0",
        "better-sqlite3": "^12.4.1",
        "dotenv": "^17.2.3",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.0",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "node-machine-id": "^1.1.12",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.13.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.14",
        "@vitejs/plugin-react": "^5.0.4",
        "@vitest/coverage-v8": "^1.6.1",
        "@vitest/ui": "^1.6.1",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "electron-packager": "^17.1.2",
        "javascript-obfuscator": "^5.3.0",
        "vite": "^6.2.0",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^1.6.1"
    }
}
